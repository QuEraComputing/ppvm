 def main():
      measurement_record = []

      for _ in range(3):
          circuit.h(q0)

          q0_outcome = circuit.measure(q0)
          measurement_record.append(q0_outcome)

          if q0_outcome == 1:
              circuit.x(q1)

      q1_outcome = circuit.measure(q1)
      measurement_record.append(q1_outcome)

      return measurement_record
