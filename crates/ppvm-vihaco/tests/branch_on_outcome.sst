device circuit.n_qubits 2;

fn @main() {
    const.u64 0
    circuit.h

    const.u64 0
    circuit.measure

    // Stack: [outcome]. No loss gate, so outcome is 0 or 1. Compare to 1
    // to derive a bool for cond_br.
    const.u32 1
    eq.u32

    cond_br @one, @zero

    @one:
        const.u64 1
        circuit.x
        br @measure_q1

    @zero:
        br @measure_q1

    @measure_q1:
        const.u64 1
        circuit.measure
        ret
}
