device circuit.n_qubits 3;

fn @main() {
    // Forward GHZ prep: H(0); CNOT(0, 1); CNOT(1, 2) → (|000⟩+|111⟩)/√2.
    const.u64 0
    gate h

    const.u64 0
    const.u64 1
    gate cnot

    const.u64 1
    const.u64 2
    gate cnot

    // `X{3}` matches exactly the Pauli word XXX. ⟨GHZ|XXX|GHZ⟩ = 1.
    const.str "X{3}"
    gate trace
    ret
}
