---
import "../styles/global.css";

interface TocItem {
  label: string;
  href: string;
}
interface Props {
  title: string;
  description?: string;
  current?: "home" | "quickstart" | "develop" | "api";
  toc?: TocItem[];
  tocTitle?: string;
}

const { title, description = "ppvm — fast Pauli propagation and stabilizer-tableau quantum simulator.", current, toc, tocTitle = "On this page" } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const nav = [
  { id: "home", label: "Overview", href: `${base}/` },
  { id: "quickstart", label: "Quick Start", href: `${base}/quickstart` },
  { id: "develop", label: "Develop", href: `${base}/develop` },
  { id: "api", label: "Reference", href: `${base}/api` },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} — ppvm</title>
    {/* Resolve and apply the theme before first paint to avoid a flash. */}
    <script is:inline>
      (() => {
        const stored = localStorage.getItem("ppvm-theme") || "auto";
        const sysDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const resolved = stored === "auto" ? (sysDark ? "dark" : "light") : stored;
        document.documentElement.setAttribute("data-theme", resolved);
        document.documentElement.setAttribute("data-theme-pref", stored);
      })();
    </script>
  </head>
  <body>
    <header class="masthead">
      <div class="masthead-inner">
        <a class="brand" href={`${base}/`}>
          <span class="brand-mark" aria-hidden="true"></span>
          <span class="brand-mono">ppvm</span>
          <span class="brand-sub">/ Pauli propagation &amp; tableau simulation</span>
        </a>
        <nav class="nav-links">
          {nav.map((n) => (
            <a href={n.href} aria-current={current === n.id ? "page" : undefined}>{n.label}</a>
          ))}
          <div class="theme-toggle" role="group" aria-label="Theme">
            <button type="button" data-theme-set="light" title="Light theme" aria-label="Light theme">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="4"/>
                <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
              </svg>
            </button>
            <button type="button" data-theme-set="dark" title="Dark theme" aria-label="Dark theme">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/>
              </svg>
            </button>
            <button type="button" data-theme-set="auto" title="Match system theme" aria-label="Auto (follow system)">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="4" width="18" height="13" rx="2"/>
                <path d="M8 21h8M12 17v4"/>
              </svg>
            </button>
          </div>
        </nav>
      </div>
    </header>
    <main>
      {toc && toc.length > 0 ? (
        <div class="page-shell">
          <aside class="page-toc" aria-label={tocTitle}>
            <div class="page-toc-label">{tocTitle}</div>
            <ol>
              {toc.map((t) => (
                <li><a href={t.href} data-toc-link={t.href}>{t.label}</a></li>
              ))}
            </ol>
          </aside>
          <div class="page-toc-content">
            <slot />
          </div>
        </div>
      ) : (
        <slot />
      )}
    </main>
    {toc && toc.length > 0 && (
      <script is:inline>
        // Scroll-spy: mark the TOC link for the section currently in view.
        // Strategy: track each section's distance from the top of the
        // viewport and pick whichever sits closest to (but above) a small
        // anchor line near the top, so the link flips just as a section's
        // heading scrolls past.
        (() => {
          const links = Array.from(document.querySelectorAll(".page-toc [data-toc-link]"));
          if (!links.length) return;

          // Pair each link with its target heading.
          const targets = links
            .map((a) => {
              const href = a.getAttribute("data-toc-link") || "";
              const id = href.startsWith("#") ? href.slice(1) : null;
              const el = id ? document.getElementById(id) : null;
              return el ? { link: a, el } : null;
            })
            .filter(Boolean);
          if (!targets.length) return;

          const ANCHOR = 120; // px from top of viewport

          function update() {
            let activeIdx = 0;
            for (let i = 0; i < targets.length; i++) {
              const top = targets[i].el.getBoundingClientRect().top;
              if (top - ANCHOR <= 0) activeIdx = i;
              else break;
            }
            for (let i = 0; i < targets.length; i++) {
              const isActive = i === activeIdx;
              targets[i].link.setAttribute("aria-current", isActive ? "true" : "false");
            }
          }

          update();
          window.addEventListener("scroll", update, { passive: true });
          window.addEventListener("resize", update);
        })();
      </script>
    )}
    <script is:inline>
      // Inject a copy button into every <pre> block.
      (() => {
        const COPY_SVG = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="11" height="11" rx="2"/><path d="M5 15V5a2 2 0 0 1 2-2h10"/></svg>';
        const CHECK_SVG = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>';

        for (const pre of document.querySelectorAll("pre")) {
          if (pre.querySelector(".copy-btn")) continue;
          const btn = document.createElement("button");
          btn.type = "button";
          btn.className = "copy-btn";
          btn.setAttribute("aria-label", "Copy code to clipboard");
          btn.innerHTML = COPY_SVG + "<span>Copy</span>";
          pre.appendChild(btn);

          btn.addEventListener("click", async () => {
            const code = pre.querySelector("code");
            const text = (code ? code.innerText : pre.innerText).replace(/\n$/, "");
            try {
              await navigator.clipboard.writeText(text);
            } catch {
              // Fallback for non-secure contexts.
              const ta = document.createElement("textarea");
              ta.value = text;
              ta.style.position = "fixed";
              ta.style.opacity = "0";
              document.body.appendChild(ta);
              ta.select();
              try { document.execCommand("copy"); } catch {}
              document.body.removeChild(ta);
            }
            btn.dataset.state = "copied";
            btn.innerHTML = CHECK_SVG + "<span>Copied</span>";
            setTimeout(() => {
              btn.removeAttribute("data-state");
              btn.innerHTML = COPY_SVG + "<span>Copy</span>";
            }, 1500);
          });
        }
      })();
    </script>
    <script is:inline>
      // Theme switcher: light / dark / auto, persisted in localStorage.
      (() => {
        const root = document.documentElement;
        const mql = window.matchMedia("(prefers-color-scheme: dark)");
        const buttons = document.querySelectorAll(".theme-toggle button[data-theme-set]");

        function apply(pref) {
          const resolved = pref === "auto" ? (mql.matches ? "dark" : "light") : pref;
          root.setAttribute("data-theme", resolved);
          root.setAttribute("data-theme-pref", pref);
          localStorage.setItem("ppvm-theme", pref);
          for (const b of buttons) {
            b.setAttribute("aria-pressed", b.dataset.themeSet === pref ? "true" : "false");
          }
        }

        const initial = localStorage.getItem("ppvm-theme") || "auto";
        apply(initial);

        for (const b of buttons) {
          b.addEventListener("click", () => apply(b.dataset.themeSet));
        }

        mql.addEventListener("change", () => {
          if ((localStorage.getItem("ppvm-theme") || "auto") === "auto") apply("auto");
        });
      })();
    </script>
    <footer class="foot">
      <div class="foot-inner">
        <span>ppvm · QuEra Computing · open source, MIT-style license</span>
        <span>
          <a href="https://github.com/QuEraComputing/ppvm">source</a> ·
          documentation generated <time>{new Date().toISOString().slice(0, 10)}</time>
        </span>
      </div>
    </footer>
  </body>
</html>
